@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<div class="row">
    <div class="col-md-6">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Username" class="form-control" placeholder="Please choose your username." disabled />
                <label asp-for="Username" class="form-label"></label>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Please enter your phone number."/>
                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <textarea asp-for="Input.AboutMe" class="form-control" rows="3" placeholder="Tell us about yourself"></textarea>
                <label asp-for="Input.AboutMe" class="form-label">About Me</label>
                <span asp-validation-for="Input.AboutMe" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.ServiceCategory" class="form-control" placeholder="e.g., Web Development, Design, Marketing" />
                <label asp-for="Input.ServiceCategory" class="form-label">Service Category</label>
                <span asp-validation-for="Input.ServiceCategory" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Location" class="form-control" placeholder="City, Country" />
                <label asp-for="Input.Location" class="form-label">Location</label>
                <span asp-validation-for="Input.Location" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.BannerImage" class="form-control" placeholder="https://example.com/banner.jpg" />
                <label asp-for="Input.BannerImage" class="form-label">Banner Image URL</label>
                <span asp-validation-for="Input.BannerImage" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.ProfilePic" class="form-control" placeholder="https://example.com/profile.jpg" />
                <label asp-for="Input.ProfilePic" class="form-label">Profile Picture URL</label>
                <span asp-validation-for="Input.ProfilePic" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.AlternativePhone" class="form-control" placeholder="+1234567890" />
                <label asp-for="Input.AlternativePhone" class="form-label">Alternative Phone</label>
                <span asp-validation-for="Input.AlternativePhone" class="text-danger"></span>
            </div>
            <button id="update-profile-button" type="submit" class="w-100 btn btn-lg btn-primary">Save</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
